generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VideoStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  googleId     String?      @unique
  authProvider String       @default("password")
  role         String       @default("USER")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  videos       Video[]
  chats        Chat[]
  settings     Setting?
}

model Video {
  id           String       @id @default(cuid())
  userId       String
  title        String
  sourceType   String
  sourceUrl    String?
  filePath     String?
  language     String       @default("en")
  status       VideoStatus  @default(QUEUED)
  durationSec  Int?
  error        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcript   Transcript?
  summary      Summary?
  chats        Chat[]
}

model Transcript {
  id               String   @id @default(cuid())
  videoId          String   @unique
  text             String
  segments         Json
  srt              String
  sourceLanguage   String?
  targetLanguage   String?
  originalText     String?
  originalSegments Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  video            Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Summary {
  id          String   @id @default(cuid())
  videoId     String   @unique
  summary     String
  keyPoints   Json
  notes       Json
  definitions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  question  String
  answer    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Setting {
  id                 String   @id @default(cuid())
  userId             String   @unique
  preferredLanguage  String   @default("en")
  autoGenerateNotes  Boolean  @default(true)
  exportFormat       String   @default("txt")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PremiumDevice {
  id        String    @id @default(cuid())
  deviceId  String    @unique
  active    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PremiumCode {
  id             String    @id @default(cuid())
  code           String    @unique
  active         Boolean   @default(true)
  expiresAt      DateTime?
  usedByDeviceId String?
  createdAt      DateTime  @default(now())
  usedAt         DateTime?
}

model Usage {
  id        String   @id @default(cuid())
  deviceId  String
  month     String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, month])
}
